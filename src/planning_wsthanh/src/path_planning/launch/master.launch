<?xml version="1.0"?>
<launch>
  <!-- Master Launch File - Starts all nodes for the autonomous vehicle system -->
  
  <!-- Launch Sensing Node: Reads serial data and publishes IMU + Odometry -->
  <!-- respawn="true" will restart if it crashes -->
  <node pkg="path_planning" type="sensing_node" name="sensing_node" output="screen" respawn="true" respawn_delay="2">
    <param name="port" value="/dev/ttyACM0"/>
    <param name="baudrate" value="115200"/>
  </node>

  <!-- Launch Localization: EKF Filter for sensor fusion -->
  <include file="$(find localization)/launch/localization.launch"/>

  <!-- Launch Global Planner: Python node to find optimal path -->
  <node pkg="path_planning" type="planner.py" name="global_planner" output="screen" />


  <!-- Launch Path Manager: Main planning node -->
  <!-- respawn="true" will restart if it crashes -->
  <node pkg="path_planning" type="path_manager_node" name="path_manager_node" output="screen" respawn="true" respawn_delay="2">
  </node>

  <!-- Static TF Publisher: Link base_link to chassis -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="base_link_to_chassis" args="0 0 0 0 0 0 base_link chassis" />

  <!-- Optional: RViz Visualization -->
  <!-- Uncomment to view the system in RViz -->
  <!-- <node pkg="rviz" type="rviz" name="rviz" args="-d $(find path_planning)/rviz/config.rviz"/> -->

</launch>
